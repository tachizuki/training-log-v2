rules_version = '2';
// PhysiqueLog 推奨 Firestore セキュリティルール
// 反映方法: Firebase Console → Firestore Database → ルール に貼り付けて「公開」
//          または firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザーデータ（クラウド同期）: 本人のみ読み書き可
    match /users/{uid} {
      allow read, write: if request.auth != null
                         && request.auth.uid == uid
                         // 1ドキュメントのサイズ上限（肥大化/濫用対策）
                         && (request.resource == null || request.resource.data.size() < 50)
                         && (request.resource == null
                             || !('data' in request.resource.data)
                             || (request.resource.data.data is string
                                 && request.resource.data.data.size() < 1500000));
      // サブコレクションは個別に許可しない限り拒否
      match /{document=**} {
        allow read, write: if false;
      }
    }

    // お問い合わせ: 作成のみ（未ログインのゲストも送信可）。閲覧/改変は不可。
    match /contacts/{docId} {
      allow create: if request.resource.data.payload is string
                    && request.resource.data.payload.size() < 8000;
      allow read, update, delete: if false;
    }

    // 上記以外はすべて拒否（デフォルト拒否）
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
